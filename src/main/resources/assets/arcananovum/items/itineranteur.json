{
    "model": {
        "type": "minecraft:select",
        "property": "minecraft:custom_model_data",
        "cases": [
            {
                "when": "yellow",
                "model": {
                    "type": "minecraft:model",
                    "model": "arcananovum:item/itineranteur_yellow"
                }
            },
            {
                "when": "blue",
                "model": {
                    "type": "minecraft:model",
                    "model": "arcananovum:item/itineranteur_blue"
                }
            },
            {
                "when": "copper",
                "model": {
                    "type": "minecraft:model",
                    "model": "arcananovum:item/itineranteur_unoxidized"
                }
            },
            {
                "when": "green",
                "model": {
                    "type": "minecraft:model",
                    "model": "arcananovum:item/itineranteur_oxidized"
                }
            }
        ],
        "fallback": {
            "type": "minecraft:model",
            "model": "arcananovum:item/itineranteur_yellow"
        }
    },
    "hand_animation_on_swap": true
}